---
import { Image } from "astro:assets";
import ToArrow from "@components/ToArrow.astro";
import SectionTitle from "@components/format/text/SectionTitle.astro";
import Paragraph from "@components/format/text/Paragraph.astro";
import Heading from "@components/format/text/Heading.astro";
import Link from "@components/format/links/Link.astro";
import ArrowLink from "@components/format/links/ArrowLink.astro";
import CenterContainer from "@components/format/containers/CenterContainer.astro";

import type { HTMLAttributes } from "astro/types";
type Props = HTMLAttributes<"section">;

import denoNotifyImage from "@assets/deno_notify.png";
import classesFyiImage from "@assets/classes_fyi.png";
---

<section {...Astro.props} class="my-12 space-y-3 pt-4">
  <CenterContainer class="px-4">
    <SectionTitle>Selected projects</SectionTitle>
  </CenterContainer>
  <div class="space-y-10">
    <!-- deno_notify -->
    <div class="space-y-3">
      <CenterContainer size="large">
        <Image
          class="w-full object-cover grayscale hover:grayscale-0 dark:grayscale-0"
          src={denoNotifyImage}
          widths={[320, 576, 672, 768, 960]}
          sizes="(min-width: 1024px) 672px, (min-width: 640px) 576px, 100vw"
          alt={'Screen capture of a macOS notification with title "deno_notify" and body "Send desktop notification on all platforms in Deno."'}
        />
      </CenterContainer>
      <CenterContainer class="space-y-3 px-4">
        <Heading>deno_notify — 2023</Heading>
        <Paragraph size="lg">
          I built TypeScript<ToArrow aria-label="to" />Rust<ToArrow
            aria-label="to"
          />ObjC bindings to send native desktop notifications in Deno.
        </Paragraph>
        <Paragraph size="lg">
          This includes work on <Link
            href="https://github.com/h4llow3En/mac-notification-sys"
          >
            <>mac_notification_sys</>
          </Link> to bridge the gap between Rust and macOS's native APIs.
        </Paragraph>
        <Paragraph size="lg">
          <ArrowLink
            class="font-normal"
            href="https://github.com/Pandawan/deno_notify"
          >
            Check it out
          </ArrowLink>
        </Paragraph>
      </CenterContainer>
    </div>
    <!-- classes.fyi -->
    <div class="space-y-3">
      <CenterContainer size="large">
        <div class="w-fit hover:bg-blue-50 dark:bg-blue-50">
          <Image
            class="w-full object-cover mix-blend-multiply grayscale"
            src={classesFyiImage}
            widths={[320, 576, 672, 768, 960]}
            sizes="(min-width: 1024px) 672px, (min-width: 640px) 576px, 100vw"
            alt={'Screen capture of the classes.fyi homepage, a service that emails users when class seats become available. The page includes a brief explanation, a campus selector dropdown to find classes, and a "See Current Class Registration" button for managing existing notifications.'}
          />
        </div>
      </CenterContainer>
      <CenterContainer class="space-y-3 px-4">
        <Heading>classes.fyi — 2021</Heading>
        <Paragraph size="lg">
          I made a website that allows students at De Anza and Foothill College
          to sign up for updates to class listings, allowing them to quickly
          enroll into a class whenever seats open up.</Paragraph
        >
        <Paragraph size="lg">
          <ArrowLink
            class="font-normal"
            href="https://github.com/Pandawan/classesfyi"
          >
            Check it out
          </ArrowLink>
        </Paragraph>
      </CenterContainer>
    </div>
  </div>
</section>
